  <property name="styleSheet">
   <string notr="true">/* ================= 特定QLabel图像显示框样式 ================= */
#lb_thumbnail0, #lb_thumbnail1, #lb_thumbnail2 {
    background-color: #505050;
    border: 2px solid #646464;
    border-radius: 5px;
    padding: 2px;
    min-width: 120px;
    min-height: 120px;
    qproperty-alignment: AlignCenter;
    qproperty-scaledContents: false;
}

/* 默认状态 */
#lb_thumbnail0, 
#lb_thumbnail1, 
#lb_thumbnail2 {
    border: 2px solid #646464;
}

/* 悬停状态 */
#lb_thumbnail0:hover, 
#lb_thumbnail1:hover, 
#lb_thumbnail2:hover {
    border: 2px solid #FF9800;
    background-color: #585858;
}

/* 选中状态 - 通过提高选择器特异性来确保优先级 */
#lb_thumbnail0[selected=&quot;true&quot;], 
#lb_thumbnail1[selected=&quot;true&quot;], 
#lb_thumbnail2[selected=&quot;true&quot;] {
    border: 4px solid #FF9800;
    background-color: #585858;
}

/* 按下状态 */
#lb_thumbnail0:pressed, 
#lb_thumbnail1:pressed, 
#lb_thumbnail2:pressed {
    border: 3px solid #FF9800;
    background-color: #646464;
}

/* 选中状态下的悬停 */
#lb_thumbnail0[selected=&quot;true&quot;]:hover, 
#lb_thumbnail1[selected=&quot;true&quot;]:hover, 
#lb_thumbnail2[selected=&quot;true&quot;]:hover {
    border: 4px solid #FF9800;
    background-color: #646464;
}

/* 禁用状态 */
#lb_thumbnail0:disabled, 
#lb_thumbnail1:disabled, 
#lb_thumbnail2:disabled {
    border: 2px solid #3A3A3A;
    background-color: #3A3A3A;
}

/* 图像显示框中的占位文本 */
#lb_thumbnail0::disabled, 
#lb_thumbnail1::disabled, 
#lb_thumbnail2::disabled {
    color: #888888;
    font-style: italic;
}</string>
  </property>
