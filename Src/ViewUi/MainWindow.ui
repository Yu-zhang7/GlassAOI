<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindowClass</class>
 <widget class="QMainWindow" name="MainWindowClass">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1104</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>GlassInspection_v3</string>
  </property>
  <property name="windowIcon">
   <iconset resource="../../Resource/GlassInspection_v3.qrc">
    <normaloff>:/Logo/Logo/Logo_icon.png</normaloff>:/Logo/Logo/Logo_icon.png</iconset>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ================= 颜色定义 ================= */
/* 主要背景色: #404040 */
/* 主要文字色: #FFFFFF */
/* 禁用文字色: rgba(255, 255, 255, 128) */
/* 强调色: #FF9800 */
/* 强调悬停色: #33FFD0 */
/* 强调边框色: #FF9800 */
/* 深灰色1: #484848 */
/* 深灰色2: #505050 */
/* 深灰色3: #585858 */
/* 深灰色4: #646464 */
/* 滚动条颜色: #6a6a6a */
/* 滚动条悬停色: #8a8a8a */
/* 边框色: #646464 */
/* 标签文字色: #ACACAC */
/* 输入背景色: #505050 */
/* 输入文字色: #FFFFFF */
/* 禁用背景色: #3A3A3A */
/* ToolButton背景色: #585858 */
/* ToolButton悬停色: #646464 */

/* ================= 基础样式 ================= */
QWidget:focus { outline: none; }

QWidget, QFrame {
    background-color: #404040;
    border: 0;
}

QGraphicsView,QGraphicsWidget {
	background-color: #3A3A3A;
}

QLabel {
    color: #FFFFFF;
	background-color: transparent;
}

QLabel::disabled {
    color: rgba(255, 255, 255, 128);
}

QMessageBox {
    background-color: #404040;
    color: #FFFFFF;
    border: 0;
}

QTextEdit {
    font-family: &quot;微软雅黑&quot;;
    color: #FFFFFF;
    background-color: #505050;
    border-radius: 5px;
    padding: 5px;
    border: 1px solid #646464;
}

QInputDialog QPlainTextEdit {
color: #FFFFFF;border-color: 
#FFFFFF;background-color: #505050; border-radius: 5px; padding: 5px; border: 1px solid #646464;}


QInputDialog QPlainTextEdit:focus {
    border: 1px solid #FF9800;
}
/* ================= 输入控件 ================= */
QLineEdit {
    background-color: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    border: 1px solid #646464;
    font-size: 12px;
    font-family: &quot;微软雅黑&quot;;
    padding: 5px 12px;
    selection-background-color: #FF9800;
    selection-color: #000000;
}

QLineEdit:focus {
    border: 1px solid #FF9800;
}

QLineEdit[echoMode=&quot;2&quot;] {
    lineedit-password-character: 9679;
}

QLineEdit::disabled {
    background-color: #3A3A3A;
    color: rgba(255, 255, 255, 100);
}

/* ================= 按钮控件 ================= */
/*QPushButton {
    border: 1px solid #242424;
    color: #FFFFFF;
    padding: 8px 15px;
    min-height: 15px;
    border-radius: 5px;
    background: #FF9800;
    font: 12pt;
}

QPushButton:hover {
    font-weight: bold;
    background-color: #33FFD0;
}
*/
QPushButton:disabled {
    color: rgba(255, 255, 255, 128);
    background: #3A3A3A;
}
QPushButton,
QToolButton {
    border: 1px solid #646464;
    color: #FFFFFF;
    padding: 8px 12px;
    min-height: 15px;
    border-radius: 5px;
    background: #585858;
}

QPushButton:hover,
QToolButton:hover {
    font-weight: bold;
    background: #646464;
    border-bottom: 2px solid #FF9800;
}

QPushButton:pressed, 
QToolButton:pressed {
    background: #505050;
}

/* ================= 单选框 ================= */
QRadioButton {
    font-family: &quot;微软雅黑&quot;;
    color: #FFFFFF;
    background-color: #404040;
    padding: 6px;
}

QRadioButton::indicator {
    width: 15px;
    height: 15px;
    border: 2px solid #FFFFFF;
    border-radius: 9px;
}

QRadioButton::indicator:checked {
    background-color: #FF9800;
}

QRadioButton::indicator:disabled {
    border: 2px solid #646464;
    background-color: #3A3A3A;
}

/* ================= 复选框 ================= */
QCheckBox {
    font-family: &quot;微软雅黑&quot;;
    color: #FFFFFF;
    background-color: transparent;
    padding: 6px;
}

QCheckBox::indicator {
    margin-top: 2px;
    width: 18px;
    height: 18px;
    border: 2px solid #FFFFFF;
    border-radius: 5px;
    background-color: transparent;
}

QCheckBox::indicator:checked {
    background-color: #FF9800;
    image: url(:/img/checked_light.png);
}

QCheckBox::indicator:disabled {
    border: 2px solid #646464;
    background-color: #3A3A3A;
}
/* 禁用状态下已选中的样式 */
QCheckBox::indicator:disabled:checked {
    border: 2px solid rgba(255, 152, 0, 0.5);  /* 使用半透明的强调色边框 */
    background-color: rgba(255, 152, 0, 0.3);  /* 使用半透明的强调色背景 */
    image: url(:/img/checked_light.png);  /* 保持选中图标 */
}

QCheckBox::indicator:unchecked {
    /* 默认未选中状态样式 */
}
/* ================= 列表控件 ================= */
QListView {
    background: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    alternate-background-color: #585858;
    border: 1px solid #646464;
    padding: 5px;
}

QListView::item {
    padding: 8px;
    margin: 2px;
    border-radius: 3px;
}

QListView::item:selected {
    color: #000000;
    background: #FF9800;
}

QListView::item:hover {
    background: #646464;
}

/* ================= 表格控件 ================= */
QTableView, QTableWidget {
    background: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    alternate-background-color: #585858;
    border: 1px solid #646464;
    padding-top: 0px;
    padding-bottom: 0px;
}

QTableView::item, QTableWidget::item {
    padding: 8px;
    margin: 0;
    border-bottom: none;
    border-left: none;
    border-right: 1px solid #646464;
    border-bottom: 1px solid #646464;
}

QTableView::item:selected, QTableWidget::item:selected {
    color: #000000;
    background: #FF9800;
}

QTableView QLineEdit, QTableWidget QLineEdit {
    color: #FFFFFF;
    background: #505050;
    border: 1px solid #646464;
    border-radius: 3px;
    padding: 3px;
}

/* ================= 表格角落区域样式 ================= */
QTableCornerButton::section {
    border-top-left-radius: 5px;
    border: 0px;
    padding: 5px;
    color: #FFFFFF;
    background: #585858;
}

/* ================= 表头样式 ================= */
QHeaderView {
    border: 0px solid #484848;
    background: #484848;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
}

QHeaderView::section:horizontal {
    border: 1px solid #646464;
    padding: 8px;
    color: #FFFFFF;
    background: #585858;
}

QHeaderView::section:horizontal:first {
    border-top-left-radius: 5px;
}

QHeaderView::section:horizontal:last {
    border-top-right-radius: 5px;
}

QHeaderView::section:vertical {
    background: #484848;
    color: #FFFFFF;
    padding: 8px;
    border-bottom: 1px solid #646464;
    border-right: 1px solid #646464;
}

QHeaderView::vertical {
    border-bottom-left-radius: 0px;
    background: #484848;
    border-top-left-radius: 0px;
}

/* ================= 滚动条 ================= */
QScrollBar:horizontal {
    height: 20px;
    background: #484848;
    border-radius: 5px;
}

QScrollBar:vertical {
    width: 20px;
    background: #383838;
    margin: 0px 0px 0px 0px;
    border-radius: 5px;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    background: transparent;
	border: none;
	height: 0px;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal,
QScrollBar::add-page:vertical, 
QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar::handle:horizontal,
QScrollBar::handle:vertical {
    background: #6a6a6a;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    min-width: 20px;
}

QScrollBar::handle:vertical {
    min-height: 20px;
}

QScrollBar::handle:horizontal:hover,
QScrollBar::handle:vertical:hover {
    background: #8a8a8a;
}

/* ================= 标签页 ================= */
QTabWidget {
    background: transparent;
    border: none;
}

QTabWidget::pane {
    border: 0px solid #242424;
	border-top: 2px solid #646464;
    border-radius: 5px;
    margin-top: -2px;
    background: #484848;
}

QTabWidget::tab-bar {
    alignment: left;
}

QTabBar::tab {
    width: 150px;
    height: 12px;
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
    color: #ACACAC;
    padding: 8px 20px;
    margin: 0px 0px 3px 0px;	/*与周边控件距离 上右下左*/
    border: 1px solid #242424;
    border-radius: 5px;
    background: #585858;
}

QTabBar::tab:selected,
QTabBar::tab:hover {
    width: 150px;
    height: 12px;
    border-bottom: 2px solid #FF9800;
    background: #646464;
}

QTabBar::tab:hover {
    font-weight: bold;
    color: #FFFFFF;
}

QTabBar::close-button {
    qproperty-icon: url(close_tab_light.png);
    padding: 2px;
}

/* ================= 状态管理 ================= */
*:disabled {
    background: #3A3A3A;
    border-color: #484848;
    color: rgba(255, 255, 255, 100);
}

/* ================= dock窗口管理 ================= */
QDockWidget {
    /*titlebar-close-icon: url(:/images/close_dock.png);*/
    /*titlebar-normal-icon: url(:/images/float_dock.png);*/
    border: 1px solid #646464;
    border-radius: 5px;
    margin: 3px;
}

QDockWidget::title {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #585858, stop:1 #484848);
    text-align: left;
    padding: 6px;
    height: 20px;
    border-bottom: 2px solid #646464; /* 拖动分隔线 */
}

QDockWidget::close-button, 
QDockWidget::float-button {
    subcontrol-position: top right;
    position: absolute;
    top: 6px;
    width: 16px;
    height: 16px;
    border: 1px solid #646464;
    border-radius: 3px;
    background: #505050;
}

QDockWidget::close-button {
    right: 6px;
}

QDockWidget::float-button {
    right: 24px;
}

QDockWidget::close-button:hover, 
QDockWidget::float-button:hover {
    background: #646464;
}

QDockWidget::close-button:pressed, 
QDockWidget::float-button:pressed {
    background: #3A3A3A;
}

/* ================= 组合框 ================= */
QComboBox {
    background-color: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    border: 1px solid #646464;
    padding: 5px 12px;
    min-height: 15px;
}

QComboBox:focus {
    border: 1px solid #FF9800;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px;
    border-left: 1px solid #646464;
    background: #585858;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

QComboBox::down-arrow {
	image: url(:/Arrow/Arrow/Down_arrow_light.png);
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background-color: #505050;
    color: #FFFFFF;
    border: 1px solid #646464;
    border-radius: 5px;
    selection-background-color: #FF9800;
    selection-color: #000000;
	margin: 15px 0 0 0; /* 添加上边距，避免遮挡编辑框 */
}
