/* ================= 微调框 ================= */
QSpinBox, QDoubleSpinBox {
    background-color: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    border: 1px solid #646464;
    padding: 5px 12px;
    min-height: 15px;
    selection-background-color: #FF9800;
    selection-color: #000000;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #FF9800;
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    /*width: 25px;*/
    height: 12px; /* 设置高度为按钮区域的一半 */
    border-left: 1px solid #646464;
    border-bottom: 1px solid #646464;
    background: #585858;
    border-top-right-radius: 4px;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    /*width: 25px;*/
    height: 12px; /* 设置高度为按钮区域的一半 */
    border-left: 1px solid #646464;
    background: #585858;
    border-bottom-right-radius: 4px;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background: #646464;
}

QSpinBox::up-button:pressed, QDoubleSpinBox::up-button:pressed,
QSpinBox::down-button:pressed, QDoubleSpinBox::down-button:pressed {
    background: #707070;
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url(:/Arrow/Arrow/Up_arrow_light.png);
    width: 10px;
    height: 10px;
    subcontrol-position: center;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url(:/Arrow/Arrow/Down_arrow_light.png);
    width: 10px;
    height: 10px;
    subcontrol-position: center;
}

QSpinBox::disabled, QDoubleSpinBox::disabled {
    background-color: #3A3A3A;
    color: rgba(255, 255, 255, 100);
}
/* ================= 日期时间控件 ================= */
QDateTimeEdit, QDateEdit, QTimeEdit {
    background-color: #505050;
    color: #FFFFFF;
    border-radius: 5px;
    border: 1px solid #646464;
    font-size: 12px;
    font-family: &quot;微软雅黑&quot;;
    padding: 5px 12px;
    min-height: 15px;
    selection-background-color: #FF9800;
    selection-color: #000000;
}

QDateTimeEdit:focus, QDateEdit:focus, QTimeEdit:focus {
    border: 1px solid #FF9800;
}

QDateTimeEdit::up-button, QDateEdit::up-button, QTimeEdit::up-button,
QDateTimeEdit::down-button, QDateEdit::down-button, QTimeEdit::down-button {
    subcontrol-origin: border;
    subcontrol-position: center right;
    width: 25px;
    border-left: 1px solid #646464;
    background: #585858;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

QDateTimeEdit::up-button:hover, QDateEdit::up-button:hover, QTimeEdit::up-button:hover,
QDateTimeEdit::down-button:hover, QDateEdit::down-button:hover, QTimeEdit::down-button:hover {
    background: #646464;
}

QDateTimeEdit::up-button:pressed, QDateEdit::up-button:pressed, QTimeEdit::up-button:pressed,
QDateTimeEdit::down-button:pressed, QDateEdit::down-button:pressed, QTimeEdit::down-button:pressed {
    background: #707070;
}

QDateTimeEdit::up-arrow, QDateEdit::up-arrow, QTimeEdit::up-arrow {
    image: url(:/Arrow/Arrow/Up_arrow_light.png);
    width: 10px;
    height: 10px;
    subcontrol-position: center;
}

QDateTimeEdit::down-arrow, QDateEdit::down-arrow, QTimeEdit::down-arrow {
    image: url(:/Arrow/Arrow/Down_arrow_light.png);
    width: 10px;
    height: 10px;
    subcontrol-position: center;
}

QDateTimeEdit::drop-down, QDateEdit::drop-down, QTimeEdit::drop-down {
    subcontrol-origin: border;
    subcontrol-position: center right;
    width: 25px;
    border-left: 1px solid #646464;
    background: #585858;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

QDateTimeEdit::drop-down:hover, QDateEdit::drop-down:hover, QTimeEdit::drop-down:hover {
    background: 646464;
}

QDateTimeEdit::drop-down:pressed, QDateEdit::drop-down:pressed, QTimeEdit::drop-down:pressed {
    background: #707070;
}

QDateTimeEdit::disabled, QDateEdit::disabled, QTimeEdit::disabled {
    background-color: #3A3A3A;
    color: rgba(255, 255, 255, 100);
}

/* ================= QDateTimeEdit CalendarPopup 样式 ================= */
QCalendarWidget {
    background-color: #505050;
    border: 1px solid #646464;
    border-radius: 5px;
}

QCalendarWidget QWidget {
    alternate-background-color: #585858;
}

QCalendarWidget QToolButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #585858, stop:1 #484848);
    color: #FFFFFF;
    font-size: 12px;
    border: 1px solid #646464;
    border-radius: 3px;
    padding: 5px;
    margin: 3px;
}

QCalendarWidget QToolButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #646464, stop:1 #545454);
}

QCalendarWidget QToolButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #484848, stop:1 #383838);
}

QCalendarWidget QSpinBox {
    background-color: #505050;
    color: #FFFFFF;
    border: 1px solid #646464;
    border-radius: 3px;
    padding: 2px;
}

QCalendarWidget QSpinBox::up-button, 
QCalendarWidget QSpinBox::down-button {
    background: #585858;
    border: 1px solid #646464;
    border-radius: 2px;
    width: 20px;
    height: 15px;
}

QCalendarWidget QSpinBox::up-button:hover, 
QCalendarWidget QSpinBox::down-button:hover {
    background: #646464;
}

QCalendarWidget QSpinBox::up-button:pressed, 
QCalendarWidget QSpinBox::down-button:pressed {
    background: #484848;
}

QCalendarWidget QSpinBox::up-arrow {
    image: url(:/Arrow/Arrow/Up_arrow_light.png);
    width: 10px;
    height: 10px;
	subcontrol-position: top;
}

QCalendarWidget QSpinBox::down-arrow {
    image: url(:/Arrow/Arrow/Down_arrow_light.png);
    width: 10px;
    height: 10px;
	subcontrol-position: bottom;
}

QCalendarWidget QComboBox {
    background-color: #505050;
    color: #FFFFFF;
    border: 1px solid #646464;
    border-radius: 3px;
    padding: 2px 5px;
    min-width: 60px;
}

QCalendarWidget QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 15px;
    border-left: 1px solid #646464;
    background: #585858;
}

QCalendarWidget QComboBox::down-arrow {
    image: url(:/Arrow/Arrow/Down_arrow_light.png);
    width: 8px;
    height: 8px;
}



QCalendarWidget QComboBox::QAbstractItemView {
    background-color: #505050;
    color: #FFFFFF;
    border: 1px solid #646464;
    border-radius: 5px;
    /*selection-background-color: #FF9800;*/
    /*selection-color: #000000;*/
    outline: 0;
    padding: 5px;
}

QCalendarWidget QComboBox::QAbstractItemView::item {
    padding: 5px 10px;
	color: #FFFFFF;
    border: none;
}

QCalendarWidget QComboBox::QAbstractItemView::item:selected {
    background-color: #FF9800;
    color: #000000;
}

QCalendarWidget QComboBox::QAbstractItemView::item:hover {
    background-color: #FF9800;
    color: #FFFFFF;
}

QCalendarWidget QAbstractItemView:enabled {
    color: #FFFFFF;
    background-color: #505050;
    selection-background-color: #FF9800;
    selection-color: #000000;
    border: 1px solid #646464;
    outline: 0;
}

QCalendarWidget QAbstractItemView:disabled {
    color: #888888;
    background-color: #3A3A3A;
    selection-background-color: #646464;
    selection-color: #FFFFFF;
}

QCalendarWidget QAbstractItemView:horizontalHeader {
    background: #585858;
    color: #FFFFFF;
    border: 1px solid #646464;
}

QCalendarWidget QAbstractItemView:verticalHeader {
    background: #585858;
    color: #FFFFFF;
    border: 1px solid #646464;
}

QCalendarWidget QAbstractItemView::corner {
    background: #585858;
    border: 1px solid #646464;
}
/* ================= GroupBox 样式 ================= */
QGroupBox {
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
    font-weight: bold;
    color: #FFFFFF;
    background-color: #484848;
    border: 1px solid #646464;
    border-radius: 5px;
    margin-top: 1ex; /* 为标题留出空间 */
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 5px;
    background-color: #585858;
    border: 1px solid #646464;
    border-radius: 3px;
    margin-top: -5px;
}

/* ================= Splitter 样式 ================= */
QSplitter::handle {
    background-color: #585858;
    border: 1px solid #585858;
	border-radius: 3px;
}

QSplitter::handle:horizontal {
    width: 4px;
    margin: 0 1px;
}

QSplitter::handle:vertical {
    height: 4px;
    margin: 1px 0;
}

QSplitter::handle:hover {
    background-color: #646464;
}

/* 当分割条被按下时的样式 */
QSplitter::handle:pressed {
    background-color: #FF9800;
}

/* ================= 状态栏样式 ================= */
QStatusBar {
    background-color: #484848; /* 使用深灰色1作为背景 */
    color: #FFFFFF; /* 主要文字色 */
    border-top: 1px solid #646464; /* 上边框与整体风格一致 */
    padding: 2px 5px;
}

QStatusBar::item {
    border: none; /* 移除所有项的边框 */
    background: transparent; /* 设置项背景透明 */
}

QStatusBar QLabel {
    color: #FFFFFF; /* 主要文字色 */
    background: transparent; /* 透明背景 */
    border: none; /* 无边框 */
    padding: 2px 5px; /* 适当的内边距 */
    font-family: &quot;微软雅黑&quot;;
    font-size: 12px;
}

QStatusBar QLabel:disabled {
    color: rgba(255, 255, 255, 128); /* 禁用文字色 */
}

/* 进度条在状态栏中的样式 */
QStatusBar QProgressBar {
    border: 1px solid #646464; /* 边框色 */
    border-radius: 3px;
    background-color: #505050; /* 输入背景色 */
    text-align: center;
    color: #FFFFFF; /* 文字颜色 */
    min-height: 15px;
    max-height: 15px;
}

QStatusBar QProgressBar::chunk {
    background-color: #FF9800; /* 强调色 */
    border-radius: 2px;
}

/* 按钮在状态栏中的样式 */
QStatusBar QPushButton {
    background-color: #585858; /* ToolButton背景色 */
    color: #FFFFFF;
    border: 1px solid #646464;
    border-radius: 3px;
    padding: 2px 8px;
    min-height: 15px;
}

QStatusBar QPushButton:hover {
    background-color: #646464; /* ToolButton悬停色 */
    border-bottom: 2px solid #FF9800; /* 强调色 */
}

QStatusBar QPushButton:pressed {
    background-color: #505050;
}

/* 分隔符样式 */
QStatusBar QFrame[frameShape=&quot;VLine&quot;] { /* VLine */
    background-color: #646464;
    max-width: 2px;
}

QStatusBar QFrame[frameShape=&quot;HLine&quot;] { /* HLine */
    background-color: #646464;
    max-height: 1px;
}

/* ================= 特殊用途控件管理 ============== */
#groupBox_Central {
    border: 2px solid #646464; /* 边框 */
	border-radius: 5px;
}
#frame_Left {
    border: 2px solid #646464; /* 边框 */
	border-radius: 5px;
	margin-top: 3px;	/* 整体下移 3px */
}</string>
